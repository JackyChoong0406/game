<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Candy Photo Mobile</title>
    <style>
        :root {
            --main-pink: #ff4081;
            --bg-blue: #a2d2ff;
            /* 自动计算格子大小，适配手机宽度 */
            --cell-size: 11vw; 
        }

        body {
            background: var(--bg-blue);
            font-family: sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 0;
            touch-action: none; /* 关键：防止手机浏览器下拉刷新 */
            overflow: hidden;
        }

        /* 顶部奖励区 */
        #header {
            width: 100%;
            background: white;
            padding: 10px 0;
            border-radius: 0 0 20px 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .score-box { font-size: 20px; font-weight: bold; color: var(--main-pink); }

        #reward-gallery {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding: 10px;
            justify-content: center;
        }
        .reward-card {
            width: 50px; height: 50px;
            background: #eee;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            position: relative;
            border: 2px solid transparent;
        }
        .reward-card.unlocked { border-color: gold; box-shadow: 0 0 8px gold; background: white; }
        .reward-card img { width: 100%; height: 100%; object-fit: cover; border-radius: 6px; display: none; }
        .reward-card.unlocked img { display: block; }

        /* 棋盘区 */
        #grid-container {
            margin: 15px 0;
            background: rgba(255,255,255,0.4);
            padding: 5px;
            border-radius: 10px;
        }
        #grid {
            display: grid;
            grid-template-columns: repeat(8, var(--cell-size));
            grid-template-rows: repeat(8, var(--cell-size));
            gap: 3px;
        }
        .cell {
            width: var(--cell-size); height: var(--cell-size);
            background: white; border-radius: 5px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; user-select: none;
        }

        /* 底部道具 */
        #footer {
            display: flex; gap: 10px; padding: 10px;
        }
        .tool-btn {
            background: var(--main-pink); color: white; border: none;
            padding: 8px 15px; border-radius: 20px; font-weight: bold;
        }
    </style>
</head>
<body>

    <div id="header">
        <div class="score-box">Score: <span id="score">0</span></div>
        <div id="reward-gallery"></div>
    </div>

    <div id="grid-container">
        <div id="grid"></div>
    </div>

    <div id="footer">
        <button class="tool-btn" onclick="location.reload()">🔄 重置</button>
        <button class="tool-btn" onclick="alert('奖励解锁后长按图片可保存')">🎁 说明</button>
    </div>

<script>
    const REWARDS_DATABASE = [
        { score: 50,  img: "https://picsum.photos/id/237/100/100" },
        { score: 150, img: "https://picsum.photos/id/102/100/100" },
        { score: 300, img: "https://picsum.photos/id/1025/100/100" }
    ];

    const width = 8;
    const candyColors = ['🍎', '🍇', '🍊', '🫐', '🍉', '🍋'];
    const grid = document.getElementById('grid');
    const scoreDisplay = document.getElementById('score');
    let squares = [];
    let score = 0;

    function init() {
        // 生成奖励位
        const gallery = document.getElementById('reward-gallery');
        REWARDS_DATABASE.forEach(res => {
            const card = document.createElement('div');
            card.className = 'reward-card';
            card.id = `reward-${res.score}`;
            card.innerHTML = `🔒<img src="${res.img}">`;
            gallery.appendChild(card);
        });

        // 生成格子并绑定触摸事件
        for (let i = 0; i < width * width; i++) {
            const square = document.createElement('div');
            square.className = 'cell';
            square.id = i;
            square.innerText = candyColors[Math.floor(Math.random() * candyColors.length)];
            
            square.ontouchstart = handleTouchStart;
            square.ontouchend = handleTouchEnd;

            grid.appendChild(square);
            squares.push(square);
        }
        setInterval(checkMatches, 200);
    }

    let startX, startY, startId;

    function handleTouchStart(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        startId = parseInt(this.id);
    }

    function handleTouchEnd(e) {
        let endX = e.changedTouches[0].clientX;
        let endY = e.changedTouches[0].clientY;
        
        let diffX = endX - startX;
        let diffY = endY - startY;
        let targetId = startId;

        // 判断滑动方向
        if (Math.abs(diffX) > Math.abs(diffY)) {
            if (diffX > 30) targetId = startId + 1; // 右滑
            else if (diffX < -30) targetId = startId - 1; // 左滑
        } else {
            if (diffY > 30) targetId = startId + width; // 下滑
            else if (diffY < -30) targetId = startId - width; // 上滑
        }

        // 执行交换
        if (targetId >= 0 && targetId < 64) {
            let temp = squares[startId].innerText;
            squares[startId].innerText = squares[targetId].innerText;
            squares[targetId].innerText = temp;
        }
    }

    function checkMatches() {
        let hasEliminated = false;
        // 简化的检查逻辑（横向纵向3个）
        for(let i=0; i<64; i++) {
            let color = squares[i].innerText;
            if (color === '') continue;
            // 横向
            if (i%8 < 6 && squares[i+1].innerText === color && squares[i+2].innerText === color) {
                squares[i].innerText = squares[i+1].innerText = squares[i+2].innerText = '';
                score += 10; hasEliminated = true;
            }
            // 纵向
            if (i < 48 && squares[i+width].innerText === color && squares[i+width*2].innerText === color) {
                squares[i].innerText = squares[i+width].innerText = squares[i+width*2].innerText = '';
                score += 10; hasEliminated = true;
            }
        }
        if (hasEliminated) {
            scoreDisplay.innerText = score;
            updateRewards();
            fillGaps();
        }
    }

    function fillGaps() {
        squares.forEach(s => {
            if(s.innerText === '') s.innerText = candyColors[Math.floor(Math.random() * candyColors.length)];
        });
    }

    function updateRewards() {
        REWARDS_DATABASE.forEach(r => {
            if(score >= r.score) document.getElementById(`reward-${r.score}`).classList.add('unlocked');
        });
    }

    init();
</script>
</body>
</html>
